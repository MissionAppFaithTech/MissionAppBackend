{
  "name": "adonisjs-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24.16.0",
    "npm": ">=11.13.0",
    "pnpm": ">=11.5.0"
  },
  "exports": {
    "./data": "./.adonisjs/client/data.d.ts",
    "./registry": "./.adonisjs/client/registry/index.ts"
  },
  "scripts": {
    "start": "node bin/server.js",
    "build": "node ace build",
    "dev": "node ace serve --hmr",
    "test": "node ace test",
    "lint": "eslint . --cache",
    "format": "prettier --check . --cache",
    "lint:fix": "eslint --fix . --cache",
    "format:fix": "prettier --write . --cache",
    "typecheck": "tsc --noEmit",
    "fallow": "fallow",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health --hotspots",
    "fallow:security": "fallow security",
    "fallow:watch": "fallow watch",
    "fallow:audit": "fallow audit",
    "fallow:audit:brief": "fallow audit --brief",
    "fallow:audit:ci": "fallow audit --gate new-only --format json --quiet",
    "prepare": "husky install"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#enums/*": "./app/enums/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#models/*": "./app/models/*.js",
    "#mails/*": "./app/mails/*.js",
    "#services/*": "./app/services/*.js",
    "#listeners/*": "./app/listeners/*.js",
    "#events/*": "./app/events/*.js",
    "#jobs/*": "./app/jobs/*.js",
    "#generated/*": "./.adonisjs/server/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#transformers/*": "./app/transformers/*.js",
    "#validators/shared/fields/*": "./app/validators/shared/fields/*.js",
    "#validators/shared/schemas/*": "./app/validators/shared/schemas/*.js",
    "#validators/user/*": "./app/validators/user/*.js",
    "#providers/*": "./providers/*.js",
    "#policies/*": "./app/policies/*.js",
    "#abilities/*": "./app/abilities/*.js",
    "#database/*": "./database/*.js",
    "#tests/*": "./tests/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#auth/*": "./app/auth/*.js",
    "#utils/*": "./app/utils/*.js",
    "#constants/*": "./app/constants/*.js"
  },
  "devDependencies": {
    "@adonisjs/assembler": "8.4.0",
    "@adonisjs/eslint-config": "3.1.0",
    "@adonisjs/prettier-config": "1.5.0",
    "@adonisjs/tsconfig": "2.0.0",
    "@commitlint/config-conventional": "21.1.0",
    "@commitlint/types": "21.1.0",
    "@japa/api-client": "3.2.1",
    "@japa/assert": "4.2.0",
    "@japa/plugin-adonisjs": "5.2.0",
    "@japa/runner": "5.3.0",
    "@poppinss/ts-exec": "1.4.4",
    "@types/luxon": "3.7.1",
    "@types/node": "25.9.3",
    "commitlint": "21.1.0",
    "eslint": "10.6.0",
    "fallow": "2.103.0",
    "husky": "9.1.7",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.4",
    "typescript": "6.0.3",
    "youch": "4.1.1"
  },
  "dependencies": {
    "@adonisjs/auth": "10.1.0",
    "@adonisjs/bouncer": "4.0.0",
    "@adonisjs/core": "7.3.4",
    "@adonisjs/cors": "3.0.0",
    "@adonisjs/lucid": "22.4.2",
    "@adonisjs/mail": "10.3.0",
    "@adonisjs/session": "8.1.0",
    "@adonisjs/shield": "9.0.0",
    "@dirupt/adonis-lucid-filter": "6.0.2",
    "@tuyau/core": "1.2.2",
    "@vinejs/vine": "4.4.0",
    "argon2": "0.44.0",
    "bullmq": "5.79.2",
    "ioredis": "5.11.1",
    "jose": "6.2.3",
    "luxon": "3.7.2",
    "pg": "8.22.0",
    "reflect-metadata": "0.2.2",
    "uuid": "14.0.0"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/middleware/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
