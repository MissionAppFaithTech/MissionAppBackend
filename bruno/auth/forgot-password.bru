meta {
  name: Esqueci minha senha
  type: http
  seq: 5
}

post {
  url: {{base_url}}/api/v1/auth/forgot-password
  body: json
  auth: none
}

body:json {
  {
    "login": "usuario@example.com"
  }
}

docs {
  Envia email com link de redefinição de senha, se o login corresponder a um
  usuário cadastrado. Sempre responde 200 com a mesma mensagem genérica —
  não revela se o email existe (evita user enumeration). Link expira em 60
  minutos.
}
