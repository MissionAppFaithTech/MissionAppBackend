meta {
  name: Get Profile
  type: http
  seq: 2
}

get {
  url: {{base_url}}/api/v1/account/profile
  body: none
  auth: bearer
}

auth:bearer {
  token: {{auth_token}}
}

docs {
  Retorna o perfil do usuário autenticado (identificado pelo access token,
  nunca por um `:id` na URL — ver ADR-0025 sobre sub-recurso singleton).
}
