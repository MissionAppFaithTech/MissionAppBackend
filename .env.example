# =============================================================================
# Aplicação
# =============================================================================
TZ=UTC
HOST=localhost
PORT=3333
NODE_ENV=development
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# =============================================================================
# Sessão
# =============================================================================
SESSION_DRIVER=cookie

# =============================================================================
# CORS
# =============================================================================
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# =============================================================================
# Banco de Dados — PostgreSQL
# =============================================================================
POSTGRES_CONTAINER_NAME=missionapp-pg
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=root
DB_PASSWORD=root
DB_DATABASE=app

# =============================================================================
# Cache / Filas — DragonflyDB
# =============================================================================
DRAGONFLY_CONTAINER_NAME=missionapp-dragonfly
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# =============================================================================
# Armazenamento de Objetos — MinIO (S3)
# =============================================================================
MINIO_CONTAINER_NAME=missionapp-minio
MINIO_API_HOST=127.0.0.1
MINIO_API_PORT=9000
MINIO_CONSOLE_HOST=127.0.0.1
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# =============================================================================
# Busca — Elasticsearch
# =============================================================================
ES_CONTAINER_NAME=missionapp-elasticsearch
ES_HOST=127.0.0.1
ES_PORT=9200
ELASTIC_NODE=http://${ES_HOST}:${ES_PORT}
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_WEB=7d
JWT_REFRESH_EXPIRES_IN_MOBILE=30d
MAIL_MAILER=resend
MAIL_FROM_NAME=MissionApp
MAIL_FROM_ADDRESS=noreply@missionapp.dev
RESEND_API_KEY=

# =============================================================================
# Frontend (BFF) — usado para montar links de email transacional
# =============================================================================
FRONTEND_URL=http://localhost:3000