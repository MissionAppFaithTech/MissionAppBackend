generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AUTHENTICATION_STATUS {
  SUCCESS
  USER_NOT_EXISTS
  INCORRECT_PASSWORD
  BLOCKED
}

// missionario, usuario e administrador
model User {
  id             String  @id @default(uuid())
  bio            String
  fullName       String
  phoneNumber    String
  username       String
  publicEmail    String?
  publicPhone    String?
  profilePicture String?

  email           String    @unique
  password_digest String
  login_attempts  Int       @default(0)
  last_login      DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  roleId String
  Role   Role   @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  missionaryAgencyId String
  MissionaryAgency   MissionaryAgency @relation(fields: [missionaryAgencyId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  churchId String?
  Church   Church? @relation(fields: [churchId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  AuthenticationAudit AuthenticationAudit[]

  @@map("users")
}

model MissionaryAgency {
  id         String @id @default(uuid())
  agencyName String

  User User[]

  @@map("missionary_agency")
}

model Church {
  id          String  @id @default(uuid())
  name        String
  churchPhone String?

  // TODO: revisar consistência de attendedBy
  attendedBy String // userId from the missionary
  // User       User   @relation(fields: [attendedBy], references: [id], onDelete: NoAction, onUpdate: Cascade)

  User User[]

  @@map("church")
}

model Role {
  id   String @id @default(uuid())
  role String

  User User[]
}

model AuthenticationAudit {
  id          Int                   @id @default(autoincrement())
  ip_address  String?
  remote_port String?
  browser     String?
  status      AUTHENTICATION_STATUS
  user_id     String?
  user        User?                 @relation(fields: [user_id], references: [id], onDelete: NoAction)
  created_at  DateTime              @default(now())

  @@map("authentication_audit")
}
